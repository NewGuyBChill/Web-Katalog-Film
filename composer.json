{
    "name": "celestview/movie-rating-platform",
    "description": "CelesView — A modern movie rating platform inspired by IMDb & Letterboxd",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Modules\\": "modules/"
        },
        "files": [
            "app/Shared/Helpers/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true
    }
}
